---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getPosts } from "../utils/posts";
import { formatDate, getCategoryPath, getPublicPath, getReadingTime } from "../utils/posts";
import { site } from "../data/site";

type Props = {
  post: CollectionEntry<"posts">;
};

const { post } = Astro.props;
const title = `${post.data.title} | ${site.name}`;
const canonical = getPublicPath(post.data.permalink);
const readingTime = getReadingTime(post.body ?? "");
const relatedPosts = (await getPosts())
  .filter((item) => item.id !== post.id && item.data.category === post.data.category)
  .slice(0, 3);
const articleJson = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description,
  image: post.data.heroImage,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    "@type": "Person",
    name: post.data.author
  },
  publisher: {
    "@type": "Organization",
    name: site.name,
    url: site.url
  },
  mainEntityOfPage: new URL(canonical, site.url).toString(),
  inLanguage: site.locale
};
---

<BaseLayout
  title={title}
  description={post.data.description}
  image={post.data.heroImage}
  canonical={canonical}
>
  <article class="article">
    <header class="article-header">
      <div class="meta">
        <a class="pill" href={getCategoryPath(post.data.category)}>{post.data.category}</a>
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        {post.data.updatedDate && (
          <span>수정 {formatDate(post.data.updatedDate)}</span>
        )}
        <span>{readingTime}분 읽기</span>
      </div>
      <h1 class="article-title">{post.data.title}</h1>
      <p class="lead">{post.data.description}</p>
      {post.data.heroImage && (
        <div class="article-image">
          <img src={post.data.heroImage} alt="" />
        </div>
      )}
    </header>
    <div class="article-body">
      <slot />
    </div>
    {post.data.tags.length > 0 && (
      <div class="tag-list" aria-label="태그">
        {post.data.tags.map((tag) => <span>#{tag}</span>)}
      </div>
    )}
    <script type="application/ld+json" set:html={JSON.stringify(articleJson)} />
  </article>
  {relatedPosts.length > 0 && (
    <section class="section related-section" aria-labelledby="related-title">
      <div class="container">
        <div class="section-head">
          <div>
            <p class="eyebrow">KEEP READING</p>
            <h2 id="related-title">같이 읽기 좋은 글</h2>
          </div>
          <p>{post.data.category} 주제의 다른 기록을 이어서 볼 수 있습니다.</p>
        </div>
        <div class="post-grid compact-grid">
          {relatedPosts.map((item) => <PostCard post={item} />)}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
