---
import "../styles/global.css";
import { nav, site } from "../data/site";

type Props = {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
};

const {
  title = site.title,
  description = site.description,
  image,
  canonical = Astro.url.pathname
} = Astro.props;

const canonicalPath = canonical
  .replace(/\/index\.html$/, "/")
  .replace(/\.html$/, "");
const canonicalUrl = new URL(canonicalPath, site.url).toString();
const imageUrl = image ? new URL(image, site.url).toString() : undefined;
const currentPath = Astro.url.pathname;
const normalizedCurrentPath = currentPath
  .replace(/\/index\.html$/, "/")
  .replace(/\.html$/, "")
  .replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta name="twitter:card" content={imageUrl ? "summary_large_image" : "summary"} />
    <script
      is:inline
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6918910185244897"
      crossorigin="anonymous"
    ></script>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: site.name,
      url: site.url,
      inLanguage: site.locale,
      description: site.description
    })} />
  </head>
  <body>
    <a class="skip-link" href="#content">본문으로 바로가기</a>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="/" aria-label={`${site.name} 홈`}>
          <span class="brand-mark">OET</span>
          <span class="brand-copy">
            <strong>{site.name}</strong>
            <span>아부다비에서 살아보니 보이는 UAE</span>
          </span>
        </a>
        <nav class="nav" aria-label="주요 메뉴">
          {nav.map((item) => {
            const itemPath = item.href.replace(/\/$/, "") || "/";
            return (
              <a
                href={item.href}
                aria-current={normalizedCurrentPath === itemPath ? "page" : undefined}
              >
                {item.label}
              </a>
            );
          })}
        </nav>
        <a class="header-contact" href="/contact">
          문의
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="footer">
      <div class="container footer-inner">
        <p>© {new Date().getFullYear()} {site.name}. 모든 글은 직접 경험과 공개 자료를 바탕으로 작성합니다.</p>
        <div class="footer-links">
          <a href="/privacy">개인정보처리방침</a>
          <a href="/terms">이용약관</a>
          <a href="/contact">문의</a>
        </div>
      </div>
    </footer>
  </body>
</html>
