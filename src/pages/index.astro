---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { site } from "../data/site";
import { formatDate, getCategoryPath, getPublicPath } from "../utils/posts";
import { getPosts } from "../utils/posts";

const posts = await getPosts();
const heroPost = posts.find((post) => post.data.heroImage) ?? posts[0];
const latestPosts = posts.slice(0, 6);
const categories = [
  {
    label: "아부다비 생활",
    href: "/life",
    description: "날씨, 교통, 루틴, 현지 생활의 실제 감각",
    accent: "teal"
  },
  {
    label: "UAE 문화",
    href: "/culture",
    description: "라마단, 마즐리스, 향, 차와 환대의 언어",
    accent: "date"
  },
  {
    label: "과거·현재·미래",
    href: "/past-present-future",
    description: "진주 무역의 기억부터 2071년 비전까지",
    accent: "gold"
  },
  {
    label: "나의 UAE 추억",
    href: "/memory",
    description: "정보보다 오래 남는 장소와 감정의 기록",
    accent: "clay"
  }
].map((item) => ({
  ...item,
  count: posts.filter((post) => post.data.category === item.label).length
}));
---

<BaseLayout title={site.title} description={site.description} image={heroPost?.data.heroImage}>
  <section class="home-hero">
    <div class="container home-hero-grid">
      <div class="home-hero-copy">
        <p class="eyebrow">UAE LIFE ARCHIVE</p>
        <h1>아부다비에서 살아보니 보이는 UAE</h1>
        <p class="lead">
          여행자의 체크리스트를 넘어, 오래 머문 사람이 기억하는 아랍에미리트의 문화와
          장소, 생활의 감각을 기록합니다.
        </p>
        <div class="hero-actions" aria-label="주요 이동">
          <a class="primary-link" href="#latest">최근 글 보기</a>
          <a class="secondary-link" href="/about">사이트 소개</a>
        </div>
      </div>

      {heroPost && (
        <a class="hero-feature" href={getPublicPath(heroPost.data.permalink)} aria-label={`${heroPost.data.title} 읽기`}>
          {heroPost.data.heroImage && (
            <img src={heroPost.data.heroImage} alt="" loading="eager" decoding="async" />
          )}
          <span class="hero-feature-label">FEATURED STORY</span>
          <strong>{heroPost.data.title}</strong>
          <span>{formatDate(heroPost.data.pubDate)} · {heroPost.data.category}</span>
        </a>
      )}
    </div>
  </section>

  <section class="section trust-band">
    <div class="container trust-grid" aria-label="사이트 운영 기준">
      <div>
        <strong>{posts.length}</strong>
        <span>개의 UAE 기록</span>
      </div>
      <div>
        <strong>4</strong>
        <span>개의 읽기 카테고리</span>
      </div>
      <div>
        <strong>경험 + 확인</strong>
        <span>개인 기록과 공개 자료를 구분해 작성</span>
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">EXPLORE</p>
          <h2>읽기 좋은 네 갈래</h2>
        </div>
        <p>아부다비 생활감, UAE 문화, 시간의 흐름, 개인의 기억을 분리해 필요한 글로 바로 이동할 수 있습니다.</p>
      </div>
      <div class="category-grid">
        {categories.map((category) => (
          <a class:list={["category-card", `accent-${category.accent}`]} href={category.href}>
            <span>{category.count} stories</span>
            <h3>{category.label}</h3>
            <p>{category.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="latest">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">LATEST STORIES</p>
          <h2>최근 기록</h2>
        </div>
        <p>새 글과 옮겨온 글을 같은 형식으로 정리해, 독자가 자연스럽게 다음 글로 이어갈 수 있게 했습니다.</p>
      </div>
      <div class="post-grid">
        {latestPosts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>

  <section class="section note-section">
    <div class="container note-panel">
      <p class="eyebrow">EDITORIAL NOTE</p>
      <h2>기록의 기준</h2>
      <p>
        개인 경험은 경험으로, 바뀔 수 있는 정보는 확인이 필요한 정보로 씁니다.
        UAE의 장소와 문화가 낯선 독자에게는 맥락을, 이미 살아본 사람에게는 추억을 남기는 사이트를 목표로 합니다.
      </p>
      <a class="secondary-link" href="/privacy">운영 정책 보기</a>
    </div>
  </section>
</BaseLayout>
