---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getPosts } from "../utils/posts";

const posts = (await getPosts()).filter((post) => post.data.category === "아부다비 생활");
---

<BaseLayout title="아부다비 생활 | On Earth Trip" description="아부다비와 UAE에서 살아보며 알게 된 일상, 교통, 계절, 생활 감각을 기록합니다.">
  <section class="page-hero">
    <div class="container page-hero-inner">
      <p class="eyebrow">ABU DHABI LIFE</p>
      <h1>아부다비 생활</h1>
      <p class="lead">여행 정보만으로는 알기 어려운 타지 생활의 리듬과 실제 경험을 모았습니다.</p>
      <p class="page-summary">{posts.length}개의 생활 기록을 모았습니다.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="post-grid">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>
</BaseLayout>
