---
import type { CollectionEntry } from "astro:content";
import { formatDate, getCategoryPath, getPublicPath } from "../utils/posts";

type Props = {
  post: CollectionEntry<"posts">;
};

const { post } = Astro.props;
const href = getPublicPath(post.data.permalink);
---

<article class:list={["post-card", !post.data.heroImage && "post-card-no-image"]}>
  {post.data.heroImage && (
    <a class="post-card-media" href={href} aria-label={`${post.data.title} 읽기`}>
      <img src={post.data.heroImage} alt="" loading="lazy" decoding="async" />
    </a>
  )}
  {!post.data.heroImage && (
    <a class="post-card-placeholder" href={href} aria-label={`${post.data.title} 읽기`}>
      <span>{post.data.category}</span>
    </a>
  )}
  <div class="post-card-body">
    <div class="meta">
      <a class="pill" href={getCategoryPath(post.data.category)}>{post.data.category}</a>
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
    </div>
    <h3><a href={href}>{post.data.title}</a></h3>
    <p>{post.data.description}</p>
    <a class="read-more" href={href} aria-label={`${post.data.title} 계속 읽기`}>
      계속 읽기
      <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
